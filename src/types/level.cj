package trade.types

import std.deriving.*

// ──────────────────────────────────────────────
// 级别枚举
// ──────────────────────────────────────────────

/// 缠论级别
/// L0 = 原始 K 线
/// L1 = 基础缠论分析（分型 → 笔 → 线段 → 中枢 → 走势类型）
/// L2 = L1 完成的走势类型 → 高级笔
/// L3 = L2 完成的走势类型 → 更高级笔
/// L4 = 最高级别
@Derive[Hashable]
public enum Level {
    | L0
    | L1
    | L2
    | L3
    | L4
}
